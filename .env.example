# Copy to `.env` for local dev, and set the same keys in Vercel → Project → Settings → Environment Variables.
# All build-time vars must be prefixed with VITE_ to be exposed to the client.

# EmailJS public key for the contact form (used in src/main.tsx).
VITE_EMAILJS_PUBLIC_KEY=

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX. Leave empty to disable analytics.
VITE_GA_MEASUREMENT_ID=

# Google Search Console verification token — the `content` value of the
# <meta name="google-site-verification"> tag. Leave empty to skip.
VITE_GSC_VERIFICATION=
